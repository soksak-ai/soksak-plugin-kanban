{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-kanban",
  "name": {
    "ko": "칸반",
    "en": "Kanban"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-kanban.git",
  "description": {
    "ko": "트리(아웃라이너) 기반 이슈 추적 — 한 트리를 칸반·간트·타임라인·트리·테이블·캘린더 여섯 뷰로. 노드는 parentId+order 로 무한 깊이. CLI/MCP 로 조작.",
    "en": "Tree (outliner) based issue tracking — one tree projected as kanban, gantt, timeline, tree, table, and calendar. Nodes have infinite depth via parentId+order. Operated via CLI/MCP."
  },
  "entry": "main.js",
  "permissions": [
    "data",
    "commands",
    "ui",
    "notify",
    "programs"
  ],
  "contributes": {
    "views": [
      {
        "id": "kanban",
        "title": {
          "ko": "칸반",
          "en": "Kanban"
        },
        "icon": "▦",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "플러그인 상태를 점검합니다",
          "en": "Pings the plugin"
        }
      },
      {
        "name": "node.add",
        "title": {
          "ko": "칸반 항목을 추가합니다",
          "en": "Adds a kanban item"
        }
      },
      {
        "name": "node.edit",
        "title": {
          "ko": "칸반 항목을 수정합니다",
          "en": "Edits a kanban item"
        }
      },
      {
        "name": "node.remove",
        "title": {
          "ko": "칸반 항목을 삭제합니다",
          "en": "Removes a kanban item"
        },
        "danger": "destructive"
      },
      {
        "name": "node.get",
        "title": {
          "ko": "칸반 항목을 조회합니다",
          "en": "Reads a kanban item"
        }
      },
      {
        "name": "node.list",
        "title": {
          "ko": "칸반 항목을 나열합니다",
          "en": "Lists kanban items"
        }
      },
      {
        "name": "outline.indent",
        "title": {
          "ko": "항목을 들여씁니다",
          "en": "Indents an item"
        }
      },
      {
        "name": "outline.outdent",
        "title": {
          "ko": "항목을 내어씁니다",
          "en": "Outdents an item"
        }
      },
      {
        "name": "outline.move",
        "title": {
          "ko": "항목을 옮깁니다",
          "en": "Moves an item"
        }
      },
      {
        "name": "outline.reorder",
        "title": {
          "ko": "항목 순서를 바꿉니다",
          "en": "Reorders items"
        }
      },
      {
        "name": "board.move",
        "title": {
          "ko": "보드에서 항목을 옮깁니다",
          "en": "Moves an item on the board"
        }
      },
      {
        "name": "board.reorder",
        "title": {
          "ko": "보드 순서를 바꿉니다",
          "en": "Reorders the board"
        }
      },
      {
        "name": "board.sort",
        "title": {
          "ko": "보드를 정렬합니다",
          "en": "Sorts the board"
        }
      },
      {
        "name": "focus.set",
        "title": {
          "ko": "포커스를 지정합니다",
          "en": "Sets the focus"
        }
      },
      {
        "name": "view.get",
        "title": {
          "ko": "뷰 상태를 조회합니다",
          "en": "Reads the view state"
        }
      },
      {
        "name": "stats",
        "title": {
          "ko": "통계를 조회합니다",
          "en": "Reads statistics"
        }
      },
      {
        "name": "timeline",
        "title": {
          "ko": "타임라인을 조회합니다",
          "en": "Reads the timeline"
        }
      },
      {
        "name": "column.list",
        "title": {
          "ko": "컬럼을 조회합니다",
          "en": "Lists columns"
        }
      },
      {
        "name": "seed",
        "title": {
          "ko": "예시 데이터를 채웁니다",
          "en": "Seeds sample data"
        }
      },
      {
        "name": "reset",
        "title": {
          "ko": "보드를 초기화합니다",
          "en": "Resets the board"
        },
        "danger": "destructive"
      },
      {
        "name": "breadcrumb",
        "title": {
          "ko": "경로를 조회합니다",
          "en": "Reads the breadcrumb"
        }
      },
      {
        "name": "prompt.put",
        "title": {
          "ko": "프롬프트를 저장합니다",
          "en": "Stores a prompt"
        }
      },
      {
        "name": "prompt.get",
        "title": {
          "ko": "프롬프트를 조회합니다",
          "en": "Reads a prompt"
        }
      },
      {
        "name": "prompt.resolve",
        "title": {
          "ko": "프롬프트를 조립합니다",
          "en": "Resolves a prompt"
        }
      }
    ],
    "nodes": [
      {
        "id": "tab",
        "description": {
          "ko": "상단 뷰 탭 — tab/<뷰>. 클릭하면 그 뷰로 전환합니다",
          "en": "View tab in the top bar — tab/<view>. Click switches to that view"
        }
      },
      {
        "id": "new-issue",
        "description": {
          "ko": "새 이슈 버튼 — 클릭하면 생성 모달을 엽니다",
          "en": "New issue button — click opens the create modal"
        }
      },
      {
        "id": "card",
        "description": {
          "ko": "보드 카드 — card/<키>. 클릭하면 자식이 있으면 그 노드로 들어가고 말단이면 상세를 엽니다",
          "en": "Board card — card/<key>. Click drills in when it has children, else opens detail"
        }
      },
      {
        "id": "row",
        "description": {
          "ko": "아웃라인 행 앵커 — row/<키>. ui.tree 로 위치·상태를 판독합니다",
          "en": "Outline row anchor — row/<key>. Read position and state via ui.tree"
        }
      },
      {
        "id": "badge",
        "description": {
          "ko": "항목 검증 배지 — badge/<키>/<pending|o|x|f>. 마지막 세그먼트가 배지 값입니다",
          "en": "Item validation badge — badge/<key>/<pending|o|x|f>. Last segment is the badge value"
        }
      },
      {
        "id": "audit",
        "description": {
          "ko": "감사 집계 배지 — audit/<키>/p<P>.o<O>.x<X>.f<F>. f>0 이면 덩어리 폐기 대상입니다",
          "en": "Audit tally badge — audit/<key>/p<P>.o<O>.x<X>.f<F>. f>0 marks the chunk for discard"
        }
      }
    ],
    "programs": [
      {
        "id": "kanban",
        "title": {
          "ko": "칸반",
          "en": "Kanban"
        },
        "path": {
          "ko": "유틸리티",
          "en": "Utility"
        },
        "kind": "view",
        "view": "kanban"
      }
    ],
    "skill": {
      "path": "skill/SKILL.md"
    }
  }
}
